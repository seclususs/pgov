{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "android-base",
      "hidden": true,
      "generator": "Ninja",
      "toolchainFile": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake",
      "cacheVariables": {
        "ANDROID_PLATFORM": "android-30",
        "ANDROID_STL": "none",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "arm64-debug",
      "displayName": "arm64-v8a Debug",
      "inherits": "android-base",
      "binaryDir": "${sourceDir}/build/arm64-v8a/debug",
      "cacheVariables": {
        "ANDROID_ABI": "arm64-v8a",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "arm64-release",
      "displayName": "arm64-v8a Release",
      "inherits": "android-base",
      "binaryDir": "${sourceDir}/build/arm64-v8a/release",
      "cacheVariables": {
        "ANDROID_ABI": "arm64-v8a",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "arm32-debug",
      "displayName": "armeabi-v7a Debug",
      "inherits": "android-base",
      "binaryDir": "${sourceDir}/build/armeabi-v7a/debug",
      "cacheVariables": {
        "ANDROID_ABI": "armeabi-v7a",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "arm32-release",
      "displayName": "armeabi-v7a Release",
      "inherits": "android-base",
      "binaryDir": "${sourceDir}/build/armeabi-v7a/release",
      "cacheVariables": {
        "ANDROID_ABI": "armeabi-v7a",
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "arm64-debug",
      "configurePreset": "arm64-debug"
    },
    {
      "name": "arm64-release",
      "configurePreset": "arm64-release"
    },
    {
      "name": "arm32-debug",
      "configurePreset": "arm32-debug"
    },
    {
      "name": "arm32-release",
      "configurePreset": "arm32-release"
    }
  ]
}
